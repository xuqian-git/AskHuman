#!/usr/bin/env bash
# Local gate matching Linux CI: cargo fmt --check + clippy -D warnings.
# Install: ./scripts/install-git-hooks.sh
# Bypass:  git commit --no-verify
set -euo pipefail

# Only gate when staged Rust sources change (docs/frontend-only commits stay fast).
if ! git diff --cached --name-only --diff-filter=ACM | grep -qE '^src-tauri/.*\.rs$'; then
  exit 0
fi

ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

echo "==> pre-commit: cargo fmt --check"
cargo fmt --manifest-path src-tauri/Cargo.toml --check

echo "==> pre-commit: cargo clippy --all-targets -D warnings"
# Warm incremental runs are usually a few seconds; cold builds can take ~1 min.
cargo clippy --manifest-path src-tauri/Cargo.toml --all-targets -- -D warnings

echo "==> pre-commit: ok"
