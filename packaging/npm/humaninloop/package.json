{
  "name": "askhuman",
  "version": "0.4.1",
  "description": "Human-in-the-loop interaction tool. The `AskHuman` CLI pops up a window (or uses Telegram) to collect human input and prints the result to stdout — usable standalone or as a dependency.",
  "license": "MIT",
  "author": "Naituw",
  "homepage": "https://github.com/Naituw/AskHuman",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Naituw/AskHuman.git"
  },
  "type": "commonjs",
  "main": "index.js",
  "types": "index.d.ts",
  "bin": {
    "AskHuman": "bin/cli.js"
  },
  "files": [
    "index.js",
    "index.d.ts",
    "bin",
    "README.md"
  ],
  "engines": {
    "node": ">=16"
  },
  "keywords": [
    "human-in-the-loop",
    "cli",
    "tauri",
    "ai",
    "askhuman",
    "prompt"
  ],
  "optionalDependencies": {
    "@humaninloop/darwin-arm64": "0.4.1",
    "@humaninloop/darwin-x64": "0.4.1",
    "@humaninloop/win32-x64": "0.4.1",
    "@humaninloop/linux-x64": "0.4.1"
  }
}
